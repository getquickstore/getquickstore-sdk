{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["**/*"],
  "exclude": ["dist", "node_modules"]
}